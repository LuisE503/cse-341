@local = http://localhost:8080
@userId = REPLACE_USER_ID
@clubId = REPLACE_CLUB_ID

#######################################
### API DOCUMENTATION
#######################################

### View API Documentation
GET {{local}}/api-docs

#######################################
### USERS ENDPOINTS
#######################################

### USERS - GET all users
GET {{local}}/users

### USERS - POST valid (Create)
POST {{local}}/users
Content-Type: application/json

{
  "fullName": "Luis Escarate",
  "email": "luis@example.com",
  "role": "student",
  "passwordHash": "hash12345",
  "isActive": true
}

### USERS - POST invalid (validation error)
POST {{local}}/users
Content-Type: application/json

{
  "fullName": "Lu",
  "email": "bad-email"
}

### USERS - GET single by ID
GET {{local}}/users/{{userId}}

### USERS - GET with invalid ID (400)
GET {{local}}/users/invalidid123

### USERS - PUT valid (Update)
PUT {{local}}/users/{{userId}}
Content-Type: application/json

{
  "fullName": "Luis Escarate Updated",
  "email": "luis.updated@example.com",
  "role": "organizer",
  "passwordHash": "hash67890",
  "isActive": true
}

### USERS - PUT invalid (validation error)
PUT {{local}}/users/{{userId}}
Content-Type: application/json

{
  "fullName": "A",
  "email": "not-an-email",
  "role": "bad-role",
  "passwordHash": "123"
}

### USERS - DELETE
DELETE {{local}}/users/{{userId}}

#######################################
### CLUBS ENDPOINTS
#######################################

### CLUBS - GET all clubs
GET {{local}}/clubs

### CLUBS - POST valid (Create)
POST {{local}}/clubs
Content-Type: application/json

{
  "name": "Coding Club",
  "category": "Technology",
  "description": "Software and programming activities",
  "contactEmail": "codingclub@campus.edu",
  "isActive": true
}

### CLUBS - POST invalid (validation error)
POST {{local}}/clubs
Content-Type: application/json

{
  "name": "",
  "category": ""
}

### CLUBS - GET single by ID
GET {{local}}/clubs/{{clubId}}

### CLUBS - GET with invalid ID (400)
GET {{local}}/clubs/invalidid123

### CLUBS - PUT valid (Update)
PUT {{local}}/clubs/{{clubId}}
Content-Type: application/json

{
  "name": "Coding Club Updated",
  "category": "Engineering",
  "description": "Updated club details",
  "contactEmail": "club.updated@campus.edu",
  "isActive": true
}

### CLUBS - PUT invalid (validation error)
PUT {{local}}/clubs/{{clubId}}
Content-Type: application/json

{
  "name": "A",
  "category": ""
}

### CLUBS - DELETE
DELETE {{local}}/clubs/{{clubId}}

#######################################
### AUTH ENDPOINTS (Optional for W05 demo)
#######################################

### AUTH - Status
GET {{local}}/auth/status

### AUTH - Login (redirect)
GET {{local}}/auth/login

### AUTH - Logout
GET {{local}}/auth/logout
