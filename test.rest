@local = http://localhost:8080
@bookId = REPLACE_BOOK_ID
@authorId = REPLACE_AUTHOR_ID

#######################################
### API DOCUMENTATION
#######################################

### View API Documentation
GET {{local}}/api-docs

#######################################
### BOOKS ENDPOINTS
#######################################

### BOOKS - GET all books
GET {{local}}/books

### BOOKS - POST valid (Create)
POST {{local}}/books
Content-Type: application/json

{
  "title": "Clean Code",
  "genre": "Software Development",
  "authorName": "Robert C. Martin",
  "publishYear": 2008,
  "pages": 464,
  "language": "English",
  "inStock": true,
  "rating": 4.7
}

### BOOKS - POST another book
POST {{local}}/books
Content-Type: application/json

{
  "title": "The Pragmatic Programmer",
  "genre": "Software Engineering",
  "authorName": "David Thomas",
  "publishYear": 1999,
  "pages": 352,
  "language": "English",
  "inStock": true,
  "rating": 4.6
}

### BOOKS - POST invalid (Missing fields - validation error)
POST {{local}}/books
Content-Type: application/json

{
  "title": "A"
}

### BOOKS - POST invalid rating (Rating > 5 - validation error)
POST {{local}}/books
Content-Type: application/json

{
  "title": "Invalid Book",
  "genre": "Fiction",
  "authorName": "Test Author",
  "publishYear": 2020,
  "pages": 300,
  "language": "English",
  "inStock": true,
  "rating": 6.0
}

### BOOKS - GET single by ID
GET {{local}}/books/{{bookId}}

### BOOKS - GET with invalid ID (400 error)
GET {{local}}/books/invalidid123

### BOOKS - PUT update (Modify)
PUT {{local}}/books/{{bookId}}
Content-Type: application/json

{
  "title": "Clean Code - Updated Edition",
  "genre": "Software Development",
  "authorName": "Robert C. Martin",
  "publishYear": 2020,
  "pages": 480,
  "language": "English",
  "inStock": true,
  "rating": 4.8
}

### BOOKS - PUT with invalid data (validation error)
PUT {{local}}/books/{{bookId}}
Content-Type: application/json

{
  "title": "A",
  "genre": "Fiction",
  "authorName": "Author",
  "publishYear": 999,
  "pages": 0,
  "language": "English",
  "inStock": true,
  "rating": 10
}

### BOOKS - DELETE
DELETE {{local}}/books/{{bookId}}

### BOOKS - DELETE with invalid ID (400 error)
DELETE {{local}}/books/invalidid123

#######################################
### AUTHORS ENDPOINTS
#######################################

### AUTHORS - GET all authors
GET {{local}}/authors

### AUTHORS - POST valid (Create)
POST {{local}}/authors
Content-Type: application/json

{
  "fullName": "Isabel Allende",
  "email": "isabel@example.com",
  "country": "Chile",
  "birthDate": "1942-08-02",
  "primaryGenre": "Fiction",
  "awardsCount": 15,
  "active": true
}

### AUTHORS - POST another author
POST {{local}}/authors
Content-Type: application/json

{
  "fullName": "Gabriel García Márquez",
  "email": "gabriel@example.com",
  "country": "Colombia",
  "birthDate": "1927-03-06",
  "primaryGenre": "Magical Realism",
  "awardsCount": 20,
  "active": true
}

### AUTHORS - POST invalid (Missing email field)
POST {{local}}/authors
Content-Type: application/json

{
  "fullName": "Test Author",
  "country": "USA"
}

### AUTHORS - POST invalid (Invalid email format)
POST {{local}}/authors
Content-Type: application/json

{
  "fullName": "Invalid Author",
  "email": "invalid-email-format",
  "country": "USA",
  "birthDate": "1980-01-01",
  "primaryGenre": "Fiction",
  "awardsCount": 5,
  "active": true
}

### AUTHORS - GET single by ID
GET {{local}}/authors/{{authorId}}

### AUTHORS - GET with invalid ID (400 error)
GET {{local}}/authors/invalidid123

### AUTHORS - PUT update (Modify)
PUT {{local}}/authors/{{authorId}}
Content-Type: application/json

{
  "fullName": "Isabel Allende Updated",
  "email": "isabel.updated@example.com",
  "country": "Peru",
  "birthDate": "1942-08-02",
  "primaryGenre": "Fiction and Drama",
  "awardsCount": 18,
  "active": true
}

### AUTHORS - PUT with invalid data (validation error)
PUT {{local}}/authors/{{authorId}}
Content-Type: application/json

{
  "fullName": "A",
  "email": "not-valid-email",
  "country": "C",
  "birthDate": "invalid",
  "primaryGenre": "F",
  "awardsCount": -5,
  "active": "not-boolean"
}

### AUTHORS - DELETE
DELETE {{local}}/authors/{{authorId}}

### AUTHORS - DELETE with invalid ID (400 error)
DELETE {{local}}/authors/invalidid123

