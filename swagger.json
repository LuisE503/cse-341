{
  "openapi": "3.0.0",
  "info": {
    "title": "W04 Project 2 API - Books, Authors, OAuth",
    "description": "REST API with CRUD for books/authors, validation, error handling, and GitHub OAuth authentication.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://cse-341-5vgx.onrender.com",
      "description": "Render deployment"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "OAuth login, status and logout"
    },
    {
      "name": "Books",
      "description": "Book collection CRUD"
    },
    {
      "name": "Authors",
      "description": "Author collection CRUD"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie set after OAuth login."
      }
    },
    "schemas": {
      "Book": {
        "type": "object",
        "required": [
          "title",
          "genre",
          "authorName",
          "publishYear",
          "pages",
          "language",
          "inStock",
          "rating"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "title": {
            "type": "string",
            "example": "Clean Code"
          },
          "genre": {
            "type": "string",
            "example": "Software"
          },
          "authorName": {
            "type": "string",
            "example": "Robert Martin"
          },
          "publishYear": {
            "type": "integer",
            "example": 2008
          },
          "pages": {
            "type": "integer",
            "example": 464
          },
          "language": {
            "type": "string",
            "example": "English"
          },
          "inStock": {
            "type": "boolean",
            "example": true
          },
          "rating": {
            "type": "number",
            "example": 4.5
          }
        }
      },
      "Author": {
        "type": "object",
        "required": [
          "fullName",
          "email",
          "country",
          "birthDate",
          "primaryGenre",
          "awardsCount",
          "active"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439012"
          },
          "fullName": {
            "type": "string",
            "example": "Isabel Allende"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "isabel@example.com"
          },
          "country": {
            "type": "string",
            "example": "Chile"
          },
          "birthDate": {
            "type": "string",
            "format": "date",
            "example": "1942-08-02"
          },
          "primaryGenre": {
            "type": "string",
            "example": "Fiction"
          },
          "awardsCount": {
            "type": "integer",
            "example": 5
          },
          "active": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "AuthStatus": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "type": ["object", "null"],
            "properties": {
              "id": {
                "type": "string"
              },
              "githubId": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "displayName": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "nullable": true
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is running"
          }
        }
      }
    },
    "/auth/login": {
      "get": {
        "tags": ["Auth"],
        "summary": "Start GitHub OAuth login",
        "responses": {
          "302": {
            "description": "Redirect to GitHub login"
          },
          "500": {
            "description": "OAuth not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "OAuth callback endpoint",
        "responses": {
          "302": {
            "description": "Redirects to /auth/status when successful"
          }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current session auth status",
        "responses": {
          "200": {
            "description": "Returns whether current request is authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Auth"],
        "summary": "Log out and destroy session",
        "responses": {
          "200": {
            "description": "Logged out"
          }
        }
      }
    },
    "/books": {
      "get": {
        "tags": ["Books"],
        "summary": "Get all books",
        "responses": {
          "200": {
            "description": "Books list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Book"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": ["Books"],
        "summary": "Create a book (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Book"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Authentication required"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "summary": "Get one book by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Book found"
          },
          "400": {
            "description": "Invalid id"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "put": {
        "tags": ["Books"],
        "summary": "Update a book (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Book"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          },
          "400": {
            "description": "Validation error or invalid id"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "delete": {
        "tags": ["Books"],
        "summary": "Delete a book (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "400": {
            "description": "Invalid id"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/authors": {
      "get": {
        "tags": ["Authors"],
        "summary": "Get all authors",
        "responses": {
          "200": {
            "description": "Authors list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Author"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": ["Authors"],
        "summary": "Create an author (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Author"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Authentication required"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/authors/{id}": {
      "get": {
        "tags": ["Authors"],
        "summary": "Get one author by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Author found"
          },
          "400": {
            "description": "Invalid id"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "put": {
        "tags": ["Authors"],
        "summary": "Update an author (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Author"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          },
          "400": {
            "description": "Validation error or invalid id"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "delete": {
        "tags": ["Authors"],
        "summary": "Delete an author (protected)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "400": {
            "description": "Invalid id"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  }
}
