{
  "openapi": "3.0.0",
  "info": {
    "title": "Campus Events and Clubs API - Week 05",
    "description": "Week 05 deliverable: CRUD + validation + error handling for first two collections (users and clubs).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cse-341-5vgx.onrender.com",
      "description": "Render deployment"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Users collection CRUD"
    },
    {
      "name": "Clubs",
      "description": "Clubs collection CRUD"
    },
    {
      "name": "Auth",
      "description": "GitHub OAuth login, status, and logout"
    }
  ],
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "required": ["fullName", "email", "role", "passwordHash"],
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "fullName": {
            "type": "string",
            "example": "Luis Escarate"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "luis@example.com"
          },
          "role": {
            "type": "string",
            "enum": ["student", "organizer", "admin"],
            "example": "student"
          },
          "passwordHash": {
            "type": "string",
            "example": "hashed-password-value"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Club": {
        "type": "object",
        "required": ["name", "category"],
        "properties": {
          "_id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439022"
          },
          "name": {
            "type": "string",
            "example": "Coding Club"
          },
          "category": {
            "type": "string",
            "example": "Technology"
          },
          "description": {
            "type": "string",
            "example": "Club for software and programming activities"
          },
          "presidentUserId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "contactEmail": {
            "type": "string",
            "format": "email",
            "example": "codingclub@campus.edu"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuthStatus": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "type": ["object", "null"],
            "properties": {
              "id": { "type": "string" },
              "githubId": { "type": "string" },
              "username": { "type": "string" },
              "displayName": { "type": "string" },
              "email": { "type": "string", "nullable": true }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Validation failed"
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": { "description": "API is running" }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users",
        "responses": {
          "200": {
            "description": "Users list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/User" }
                }
              }
            }
          },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": { "description": "Server error" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get one user by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "User found" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update a user",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "204": { "description": "Updated" },
          "400": { "description": "Validation error or invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete a user",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/clubs": {
      "get": {
        "tags": ["Clubs"],
        "summary": "Get all clubs",
        "responses": {
          "200": {
            "description": "Clubs list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Club" }
                }
              }
            }
          },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "tags": ["Clubs"],
        "summary": "Create a club",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Club" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Validation error" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/clubs/{id}": {
      "get": {
        "tags": ["Clubs"],
        "summary": "Get one club by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Club found" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "tags": ["Clubs"],
        "summary": "Update a club",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Club" }
            }
          }
        },
        "responses": {
          "204": { "description": "Updated" },
          "400": { "description": "Validation error or invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "tags": ["Clubs"],
        "summary": "Delete a club",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/auth/login": {
      "get": {
        "tags": ["Auth"],
        "summary": "Start GitHub OAuth login",
        "responses": {
          "302": { "description": "Redirect to GitHub login" },
          "500": { "description": "OAuth not configured" }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "OAuth callback endpoint",
        "responses": {
          "302": { "description": "Redirect to /auth/status when successful" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current auth status",
        "responses": {
          "200": {
            "description": "Auth status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthStatus" }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Auth"],
        "summary": "Log out and destroy session",
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    }
  }
}
